# Server
PORT=4000
CORS_ORIGIN=*

# Postgres (shared pgvector container from root docker-compose)
DB_HOST=localhost
DB_PORT=5432
DB_USER=dqplus
DB_PASSWORD=hackathondqplus
DB_NAME=vietnexus

# Auth
JWT_SECRET=change-me
JWT_EXPIRES_IN=1d

# LLM provider (FPT Cloud, OpenAI-compatible). Empty key => local fallback embeddings,
# extraction/assessment/rerank/nl-filter degrade gracefully.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://mkp-api.fptcloud.com
OPENAI_CHAT_MODEL=gemma-4-31B-it
OPENAI_EMBEDDING_MODEL=multilingual-e5-large
EMBEDDING_DIM=1024

# Matching
MATCH_VECTOR_WEIGHT=0.7
MATCH_ATTR_WEIGHT=0.3
MATCH_CANDIDATE_POOL=50

# Pipeline worker
PIPELINE_POLL_MS=1000

# Email (unset SMTP_HOST => notifications logged to console instead of sent)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=VietNexus <no-reply@vietnexus.local>

# Uploads
UPLOAD_DIR=uploads
